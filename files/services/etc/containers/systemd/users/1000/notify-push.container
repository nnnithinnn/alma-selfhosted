# Nextcloud notify_push — High Performance Backend / Client Push (rootless).
#
# Runs the Rust push server that ships INSIDE the `notify_push` app (installed
# from the app store by nextcloud-apps-init.service). It holds open WebSocket
# connections to clients and pushes change notifications, replacing constant
# polling — a big CPU/latency win.
#
# Networks:
#   - web  -> Caddy proxies `/push/*` to `notify-push:7867`.
#   - data -> it connects to the SAME Postgres and Valkey as the app (to read
#     sessions and subscribe to the update pub/sub stream).
#
# It reads everything (DB DSN, Redis/Valkey, instance URL) from the app's own
# config.php, mounted read-only via the shared `nextcloud-html` volume. No
# secrets are needed here: the credentials already live in config.php (written
# by the app entrypoint from the *_FILE secrets).
#
# The push binary only exists AFTER the app is installed, so on a fresh first
# boot this unit will fail-and-restart until nextcloud-apps-init has installed
# `notify_push`; Restart=always makes that self-healing.
#
# Uses the same digest-pinned Nextcloud image as nextcloud.container.

[Unit]
Description=Nextcloud notify_push (High Performance Backend)
Documentation=https://github.com/nextcloud/notify_push
After=network-online.target
Wants=network-online.target
# Needs the app code (config.php + the push binary) to exist first.
Requires=nextcloud.service
After=nextcloud.service nextcloud-apps-init.service

[Container]
Image=public.ecr.aws/docker/library/nextcloud:33.0.5-apache@sha256:96f8b6ad4adf4044ac6d3cbc10ef99b4897c90792782b5b60a5700e5b1b97b84

# Front-end (Caddy reaches :7867) + isolated back-end (DB/Valkey). No PublishPort.
Network=web.network
Network=data.network
NetworkAlias=notify-push

# Shared app code/config, read-only — the push server only reads config.php.
Volume=nextcloud-html:/var/www/html:ro

# Run the bundled push server against the app's live config (auto-derives DB,
# Valkey and the instance URL). Listens on :7867 (the default).
Exec=/var/www/html/custom_apps/notify_push/bin/x86_64/notify_push /var/www/html/config/config.php

# Liveness: TCP connectivity on the push server port. curl without --fail so
# any HTTP response (even 404) counts as healthy; only a refused/timed-out
# connection is unhealthy. Large start period covers first-boot app-install
# delay: the binary doesn't exist until nextcloud-apps-init finishes.
HealthCmd=curl -s -o /dev/null http://localhost:7867/
HealthStartPeriod=300s
HealthInterval=30s
HealthTimeout=5s
HealthRetries=3

[Service]
Restart=always
# Tolerate restart churn on first boot until the app is installed.
RestartSec=10
TimeoutStartSec=300

[Install]
WantedBy=default.target
