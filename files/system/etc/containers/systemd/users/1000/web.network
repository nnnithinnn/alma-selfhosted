# Shared front-end ("web") container network.
#
# Rootless network for the reverse-proxy tier: Caddy joins this, and Headscale
# and Nextcloud will join it too so Caddy can reach them by container name
# (aardvark-dns provides name resolution on the bridge).
#
# A separate "data" network (Postgres/Valkey <-> Nextcloud only) is added in the
# database phase so the DB tier is never reachable from the proxy tier.
#
# No [Install] section is needed: Quadlet generates web-network.service and pulls
# it in automatically as a dependency of any container that sets Network=web.network.

[Unit]
Description=Shared front-end (web) container network

[Network]
NetworkName=web
# Pin an explicit subnet so the front-end tier has a stable CIDR. Nextcloud
# sets TRUSTED_PROXIES to this range so it trusts the X-Forwarded-* headers
# Caddy sends (Caddy's container IP is allocated from here). Without a fixed
# subnet the rootless pool address could change across rebuilds.
Subnet=10.10.10.0/24
