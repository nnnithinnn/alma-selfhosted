# =============================================================================
# config.env — single source of truth for all deployment customizations.
#
# These values are baked into the image at BUILD time: build.sh sources this
# file and 00-config.sh substitutes the @@TOKEN@@ placeholders found in the
# files under files/base, files/services and files/optionals.
#
# To re-deploy for a different person/host, edit ONLY this file (and swap the
# SSH public key in files/base/etc/ssh/authorized_keys.d/), then rebuild.
#
# Format: KEY=value  (no spaces around =, used verbatim). Shell-style: quote any
# value containing shell metacharacters such as ';' (e.g. the DNS lists below).
# Do not use shell expansions here.
# =============================================================================

# --- Identity ----------------------------------------------------------------
# System (Linux) user that owns the rootless container stack. By convention this
# is the same as your Nextcloud subdomain so the repo is trivially reusable.
# This becomes the login name, the sudo user, the SSH key owner and the rootless
# Podman namespace owner. (The Quadlet dir is keyed by UID 1000, not the name.)
APP_USER=cld

# Nextcloud's initial web admin account (first-run install only). Defaults to
# the same name as APP_USER.
NEXTCLOUD_ADMIN_USER=cld

# --- Domains -----------------------------------------------------------------
# Base domain (reference only; the service hosts below are fully qualified).
DOMAIN=nithin.nl

# Headscale control server (Caddy terminates TLS, reverse-proxies to headscale).
HEADSCALE_HOST=vpn.nithin.nl

# Nextcloud public hostname.
NEXTCLOUD_HOST=cld.nithin.nl

# Headscale MagicDNS base domain. MUST differ from HEADSCALE_HOST's domain.
MAGICDNS_BASE_DOMAIN=mesh.nithin.nl

# ACME / Let's Encrypt account contact (expiry + recovery notices).
ACME_EMAIL=hi@nithin.nl

# --- Nextcloud ---------------------------------------------------------------
# Default region for parsing national phone numbers (ISO 3166-1 alpha-2).
NEXTCLOUD_PHONE_REGION=IN

# Pinned subnet for the rootless front-end ("web") container network. Nextcloud
# trusts this range as TRUSTED_PROXIES (Caddy's X-Forwarded-* headers).
WEB_SUBNET=10.10.10.0/24

# --- Static networking (files/optionals) -------------------------------------
# The static-IP NetworkManager profile binds to this NIC by MAC, so it only
# activates on the real VPS (QEMU test VMs keep DHCP). Verify on first deploy.
NET_MAC=00:3B:DB:95:9F:7F

# IPv4 (mandatory; host is unreachable if this fails to come up).
NET_IPV4_CIDR=96.9.231.123/24
NET_IPV4_ADDR=96.9.231.123
NET_IPV4_GATEWAY=96.9.231.1
NET_IPV4_DNS="1.1.1.1;9.9.9.9;"

# IPv6 (best-effort). Primary address is NET_IPV6_ADDR; the profile assigns all
# four. Gateway is intentionally in a different /64 (verify routing on deploy).
NET_IPV6_ADDR=2a11:8083:11:169a::a
NET_IPV6_1=2a11:8083:11:169a::a/64
NET_IPV6_2=2a11:8083:11:169a::b/64
NET_IPV6_3=2a11:8083:11:169a::c/64
NET_IPV6_4=2a11:8083:11:169a::d/64
NET_IPV6_GATEWAY=2a11:8083:11::1
NET_IPV6_DNS="2606:4700:4700::1111;2620:fe::fe;"
