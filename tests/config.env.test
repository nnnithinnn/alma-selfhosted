# alma-selfhosted — test configuration for golden-file CI tests.
#
# All values are fake/reserved and safe to commit:
#   - Domains: RFC 2606 reserved (.example.com)
#   - IPs:     RFC 5737 (192.0.2.x) and RFC 3849 (2001:db8::x) documentation ranges
#   - SSH key: tests/test_key.pub — test-only keypair, never deployed
#   - Password hash: SHA-512 crypt of "testpassword" with fixed salt
#
# NEVER USE THESE VALUES ON A REAL SYSTEM.

# Identity
APP_USER='testuser'
NEXTCLOUD_ADMIN_USER='ncadmin'

# Domains
DOMAIN='test.example.com'
HEADSCALE_HOST='vpn.test.example.com'
NEXTCLOUD_HOST='cloud.test.example.com'
MAGICDNS_BASE_DOMAIN='mesh.test.example.com'
ACME_EMAIL='test@test.example.com'

# Nextcloud
NEXTCLOUD_PHONE_REGION='US'
WEB_SUBNET='10.88.0.0/24'

# Static networking (NET_MAC is set so the nmconnection template is exercised)
NET_MAC='02:00:00:00:00:01'
NET_IPV4_CIDR='192.0.2.10/24'
NET_IPV4_ADDR='192.0.2.10'
NET_IPV4_GATEWAY='192.0.2.1'
NET_IPV4_DNS='1.1.1.1;9.9.9.9;'
NET_IPV6_ADDR='2001:db8::10/64'
NET_IPV6_1='2001:db8::10/64'
NET_IPV6_2=''
NET_IPV6_3=''
NET_IPV6_4=''
NET_IPV6_GATEWAY='2001:db8::1'
NET_IPV6_DNS='2606:4700:4700::1111;2620:fe::fe;'

# SSH public key — contents of tests/test_key.pub (test-only, never deployed)
SSH_PUBKEY='ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMv5u+4LtTeowOsImPLVHvy7ZU/U/KeGCfYC3kPJacDm test-only — never deployed'

# SHA-512 crypt of "testpassword" with salt "testsalt12345678"
# Deterministic: openssl passwd -6 -salt 'testsalt12345678' 'testpassword'
APP_PASSWORD_HASH='$6$testsalt12345678$WI2DCJhjAW3sKnztNRkJ.WMKITywnBIgIQ3D1Mlte2nqXVq0B.wxCArpUOkM4ehfI4Q14yVwvMRUQTd6.7Sh1/'
